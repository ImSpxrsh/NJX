PUBLIC_APP_URL=http://localhost:3000
CIRCLECHECK_REPOSITORY_MODE=demo
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
EVIDENCE_EXTRACTOR_MODE=fixture
ANTHROPIC_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
NEXT_PUBLIC_TWILIO_PHONE_NUMBER=
# Public scheme+host Twilio calls; used to reconstruct the signed URL behind a
# proxy/Vercel. Falls back to PUBLIC_APP_URL. Pinning this ignores spoofable
# forwarded headers (recommended in production).
TWILIO_PUBLIC_BASE_URL=
# Non-production only: permit unsigned Twilio webhooks for local development.
# Never honored when NODE_ENV=production. Leave unset/false otherwise.
TWILIO_ALLOW_UNSIGNED=false
DEMO_HOUSEHOLD_ID=00000000-0000-4000-8000-000000000001
DEMO_TRUSTED_CONTACT_ID=00000000-0000-4000-8000-000000000002
NEXT_PUBLIC_DEMO_HOUSEHOLD_ID=00000000-0000-4000-8000-000000000001
VERIFICATION_TOKEN_TTL_MINUTES=10

# --- Enrollment destination verification (CC-202) ---
# Short-lived enrollment secrets and strict abuse limits. All optional; safe
# defaults apply. ENROLLMENT_DEMO_MODE is disabled by default and is only
# honored when CIRCLECHECK_REPOSITORY_MODE=demo, so it cannot affect production.
ENROLLMENT_TOKEN_TTL_MINUTES=15
ENROLLMENT_MAX_ATTEMPTS=5
ENROLLMENT_START_LIMIT=3
ENROLLMENT_START_WINDOW_MS=600000
ENROLLMENT_CONFIRM_LIMIT=10
ENROLLMENT_CONFIRM_WINDOW_MS=600000
ENROLLMENT_DEMO_MODE=off
# Set to "off" to silence the structured audit emitter (defaults to on).
CIRCLECHECK_AUDIT_LOG=on
