PUBLIC_APP_URL=http://localhost:3000

# Runtime mode controls which features are enabled server-side.
# Accepted values: "demo" or "supabase".
# - "demo"     — enables in-memory demo store, demoContactUrl in /api/analyze,
#                /api/demo/reset endpoint, and the non-production banner.
#                Demo mode is DISABLED by default. It requires an explicit value.
#                False-like strings ("false", "0", "no", "off"), mixed-case variants,
#                and any other string do NOT enable demo mode.
# - "supabase" — connects to Supabase; disables all demo-only behavior.
# In production deployments, this must be set to "supabase".
# Setting NODE_ENV=production together with CIRCLECHECK_REPOSITORY_MODE=demo
# is contradictory and resolves to production (demo features disabled).
CIRCLECHECK_REPOSITORY_MODE=demo

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
EVIDENCE_EXTRACTOR_MODE=fixture
ANTHROPIC_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
NEXT_PUBLIC_TWILIO_PHONE_NUMBER=
DEMO_HOUSEHOLD_ID=00000000-0000-4000-8000-000000000001
DEMO_TRUSTED_CONTACT_ID=00000000-0000-4000-8000-000000000002
NEXT_PUBLIC_DEMO_HOUSEHOLD_ID=00000000-0000-4000-8000-000000000001
VERIFICATION_TOKEN_TTL_MINUTES=10
